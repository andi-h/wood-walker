# Ignore build directories
/build/
/install/
/log/

# Ignore Python egg and cache files
__pycache__/
*.egg-info/
*.egg
*.pyc
*.pyo

# Ignore ROS 2 specific files
*.action
*.pb2.py
*.pb2_grpc.py

# Ignore VS Code settings
.vscode/
.history/

# Ignore environment files
.env
*.env.local

# Ignore coverage reports
coverage.xml
*.coverage
htmlcov/
*.cover

# Ignore CMake files and generated files
CMakeLists.txt.user
CMakeFiles/
cmake_install.cmake

# Ignore other autogenerated files
*.o
*.a
*.so
*.dSYM/
*.log
*.swp
*.swo

# Ignore IDE specific files
.idea/
*.iml
*.ipr

# Ignore backup files
*~ 
*.bak

# Ignore temporary files
tmp/
temp/

# Ignore other common files
.DS_Store
Thumbs.db
