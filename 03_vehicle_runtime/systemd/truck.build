# Not active now. Will work when Ubuntu upgrades to Podman 5

[Unit]
Description=Build the Truck ROS 2 container
After=local-fs.target network.target enable-linger.service
Requires=network.target enable-linger.service

[Build]
ImageTag=localhost/truck:release
File=/home/ww/wood-walker/03_vehicle_runtime/.devcontainer/Dockerfile
Target=release
Context=/home/ww/wood-walker/03_vehicle_runtime

BuildArg=WORKSPACE_FOLDER=/workspaces/wood-walker/03_vehicle_runtime

#[Service]
#TimeoutStartSec=7200
